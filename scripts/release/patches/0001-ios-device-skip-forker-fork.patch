 #ifdef ISC32
 #include <sys/bsdtypes.h>
 #endif
@@ -1587,6 +1592,16 @@ extern struct termios erl_sys_initial_tty_mode;
 static ErlDrvData forker_start(ErlDrvPort port_num, char* name,
                                SysDriverOpts* opts)
 {
+#if defined(__IOS__) && TARGET_OS_IPHONE && !TARGET_OS_SIMULATOR
+    /* dala_dev iOS device patch: iOS device sandbox blocks fork(). Skip
