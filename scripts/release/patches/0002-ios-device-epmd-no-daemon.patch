--- a/erts/epmd/src/epmd.c
+++ b/erts/epmd/src/epmd.c
@@ -236,8 +236,14 @@ int main(int argc, char** argv)
       g->max_conn = FD_SETSIZE;
     }
 
+    /* dala_dev iOS device patch: NO_DAEMON strips run_daemon to avoid
